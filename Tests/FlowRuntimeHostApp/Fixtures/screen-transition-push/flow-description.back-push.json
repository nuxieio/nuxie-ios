{
  "screens": [
    {
      "id": "screen_1",
      "defaultViewModelId": null,
      "defaultInstanceId": null
    },
    {
      "id": "screen_2",
      "defaultViewModelId": null,
      "defaultInstanceId": null
    }
  ],
  "interactions": {
    "__global__": [
      {
        "id": "interaction_auto_push",
        "enabled": true,
        "trigger": {
          "type": "event",
          "eventName": "__nuxie_test_run_transition"
        },
        "actions": [
          {
            "type": "navigate",
            "screenId": "screen_2",
            "transition": {
              "type": "push",
              "direction": "right",
              "durationMs": 550,
              "easing": "ease_in_out"
            }
          }
        ]
      }
    ],
    "screen_2": [
      {
        "id": "interaction_auto_back",
        "enabled": true,
        "trigger": {
          "type": "event",
          "eventName": "$screen_shown"
        },
        "actions": [
          {
            "type": "back",
            "steps": 1,
            "transition": {
              "type": "push",
              "direction": "left",
              "durationMs": 550,
              "easing": "ease_in_out"
            }
          }
        ]
      }
    ]
  }
}
